# Variables de entorno - COPIA ESTE ARCHIVO a .env y configura tus valores
# NO subas tu archivo .env a GitHub por seguridad

# Base de datos PostgreSQL (obligatoria)
DATABASE_URL="postgres://usuario:password@host:puerto/basededatos?sslmode=require"
PRISMA_DATABASE_URL="postgres://usuario:password@host:puerto/basededatos?sslmode=require"

# JWT Secret para autenticación (genera una clave segura)
JWT_SECRET="tu-clave-secreta-aqui"

# Google Gemini API Key (obligatoria para análisis de datos)
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY="tu-gemini-api-key-aqui"

# Configuración del entorno
NODE_ENV="development"

# Variables adicionales para compatibilidad (opcional)
POSTGRES_URL="postgres://usuario:password@host:puerto/basededatos?sslmode=require"
PRISMA_GENERATE_DATAPROXY="true"