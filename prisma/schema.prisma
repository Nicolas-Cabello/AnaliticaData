// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Configuración adaptable para desarrollo (SQLite) y producción (PostgreSQL)
datasource db {
  provider = "sqlite"  // Para desarrollo local
  // provider = "postgresql"  // Descomentar para producción en Vercel
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  dataFiles   DataFile[]
  
  @@map("users")
}

model DataFile {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   // 'csv', 'json', 'xlsx'
  columns     String   // JSON string de column names (SQLite compatible)
  data        String   // JSON string de datos (SQLite compatible)
  totalRows   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("data_files")
}
