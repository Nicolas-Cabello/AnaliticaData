// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Configuración universal para PostgreSQL (desarrollo y producción)
datasource db {
  provider = "postgresql"  // PostgreSQL para todos los entornos
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  dataFiles   DataFile[]
  
  @@map("users")
}

model DataFile {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   // 'csv', 'json', 'xlsx'
  columns     Json     // JSON de column names (PostgreSQL compatible)
  data        Json     // JSON de datos (PostgreSQL compatible)
  totalRows   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("data_files")
}
